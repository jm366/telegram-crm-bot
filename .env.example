# ── Telegram ──
TELEGRAM_BOT_TOKEN=

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── CRM Provider ──
# Options: "zoho" | "hubspot" | "pipedrive" | "salesforce" | "bitrix24" | "odoo" | "gtm-os"
CRM_PROVIDER=zoho

# ── Zoho CRM (v6) OAuth2 ──
# Get these from https://console.zoho.com/ after creating a CRM extension
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DC=us           # us, eu, in, cn, au, jp
ZOHO_OAUTH_FILE=.zoho_tokens.json

# ── HubSpot CRM ──
# Create a Private App: Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=

# ── Pipedrive CRM ──
# Settings → Personal Preferences → API → Generate token
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=           # yourcompany in https://yourcompany.pipedrive.com

# ── Salesforce CRM ──
# Setup → App Manager → Connected App → Consumer Key/Secret
SFDC_CLIENT_ID=
SFDC_CLIENT_SECRET=
SFDC_REFRESH_TOKEN=
SFDC_ACCESS_TOKEN=
SFDC_INSTANCE_URL=

# ── Bitrix24 CRM ──
# Webhook mode (easiest): Applications → Webhooks → Inbound webhook
# Or OAuth mode: Applications → OAuth
BITRIX_WEBHOOK_URL=https://yourcompany.bitrix24.com/rest/1/TOKEN/
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_REFRESH_TOKEN=
BITRIX_DOMAIN=https://yourcompany.bitrix24.com

# ── Odoo CRM ──
# Settings → Users → API Keys
ODOO_URL=https://mycompany.odoo.com
ODOO_DB=mycompany_db
ODOO_USERNAME=admin@mycompany.com
ODOO_PASSWORD=your_api_key

# ── GTM-OS (local SQLite) ──
# Used when CRM_PROVIDER=gtm-os
GTMO_DB_PATH=/root/projects/gtm-os/gtm.db
GTMO_APP_URL=https://samwise.yourdomain.com
